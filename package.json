{
  "name": "figma-mcp-server",
  "version": "1.0.0",
  "description": "MCP server connecting Claude Code to Figma — browse files, navigate pages, and convert designs to HTML/CSS",
  "type": "module",
  "bin": {
    "figma-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "figma",
    "mcp",
    "claude-code",
    "model-context-protocol",
    "figma-to-html"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
